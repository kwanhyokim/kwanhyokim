<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.sktechx.godmusic.personal.rest.repository.BadgeTypeMapper">

    <select id="findAllBadgeType" resultType="com.sktechx.godmusic.personal.rest.domain.badge.BadgeTypeDto">
        SELECT  a.badge_type_nm,
                a.issu_bf_img_url,
                a.background_rgb_value
        FROM    tb_badge_type a
        WHERE   a.use_yn = 'Y'
        ORDER BY a.disp_sn
    </select>

</mapper>